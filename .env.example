# MySQL Configuration
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wordpress
DB_USERNAME=username
DB_PASSWORD=password

# WordPress Configuration
WORDPRESS_DB_HOST="${DB_HOST}"
WORDPRESS_DB_NAME="${DB_DATABASE}"
WORDPRESS_DB_USER="${DB_USERNAME}"
WORDPRESS_DB_PASSWORD="${DB_PASSWORD}"
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=false

#WordPress CLI Configuration
WP_SITE_URL=http://localhost:8080
WP_SITE_TITLE=WordJima
WP_ADMIN_USER=user
WP_ADMIN_PASSWORD=pass
WP_ADMIN_EMAIL=admin@local.dev
WP_LOCALE=es_ES

# WordPress Authentication Keys and Salts 
#Obtain the data from https://api.wordpress.org/secret-key/1.1/salt/
AUTH_KEY='xxx'
SECURE_AUTH_KEY='xxxx'
LOGGED_IN_KEY='xxxx'
NONCE_KEY='xxxx'
AUTH_SALT='xxxx'
SECURE_AUTH_SALT='xxxx'
LOGGED_IN_SALT='xxxx'
NONCE_SALT='xxxx'

